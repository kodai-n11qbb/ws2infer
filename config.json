{
  "server": {
    "host": "localhost",
    "port": 8181,
    "max_connections": 10,
    "buffer_size": 4096
  },
  "model": {
    "path": "model.onnx",
    "backend": "auto",
    "input_size": [224, 224],
    "batch_size": 1
  },
  "inference": {
    "device": "auto",
    "num_threads": 4,
    "optimization_level": 1
  },
  "preprocessing": {
    "normalize": true,
    "mean": [0.485, 0.456, 0.406],
    "std": [0.229, 0.224, 0.225],
    "resize_method": "bilinear"
  },
  "logging": {
    "level": "info",
    "file": "ws2infer.log",
    "console": true
  }
}