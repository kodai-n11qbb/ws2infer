        B5["Generate Response Payload"]
    end

    subgraph ModelStore["AI Resources"]
        C1["Local Model(s)"]
        C2["Remote AI API (e.g., Cloud)"]
    end

    subgraph Output["Result Delivery"]
        D1["Send Inference Result via WebSocket"]
        D2["Client Receives & Displays Result"]
    end

    Client --> B1
    B1 --> B2
    B2 -->|Offline| B3 --> C1
